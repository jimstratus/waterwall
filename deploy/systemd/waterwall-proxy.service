[Unit]
Description=Waterwall reversible-tokenization egress proxy
After=network.target
Documentation=file:///opt/waterwall/docs/superpowers/specs/2026-05-05-waterwall-design.md

[Service]
Type=exec
User=waterwall
Group=waterwall

Environment=HTTPS_PROXY= NO_PROXY=127.0.0.1,localhost
Environment=WATERWALL_CHAIN=/var/log/waterwall/proxy.jsonl
Environment=WATERWALL_SIGNING_KEY=/etc/waterwall/signing.key
Environment=WATERWALL_PATTERNS=/etc/waterwall/patterns.py
Environment=WATERWALL_CONFIG=/etc/waterwall/config.yaml
Environment=WATERWALL_ADMIN_PORT=8889

ExecStartPre=/opt/waterwall/bin/waterwall verify-install
ExecStart=/opt/waterwall/.venv/bin/mitmdump \
    -s /opt/waterwall/src/waterwall/proxy/addon.py \
    --allow-hosts 'api\.anthropic\.com|api\.deepseek\.com|api\.openai\.com|openrouter\.ai' \
    --listen-host 127.0.0.1 \
    -p 8888 \
    --set stream_large_bodies=10m \
    --set confdir=/etc/waterwall \
    --set script_reloader=false \
    --set upstream_cert=false

Restart=on-failure
RestartSec=5

# Hardening (spec §15)
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
ProcSubset=pid
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
# MemoryDenyWriteExecute=yes is INCOMPATIBLE with mitmproxy: pyopenssl uses
# cffi callbacks for ALPN/SNI which require executable mmap. Disabling this
# directive trades one layer of hardening for the ability to do TLS
# interception. v1.1 candidate: spawn a privileged signer subprocess with
# MDWE=no while keeping the proxy under MDWE=yes — non-trivial refactor.
SystemCallFilter=@system-service @network-io ~@privileged
SystemCallArchitectures=native
CapabilityBoundingSet=
AmbientCapabilities=

# Limits
MemoryMax=512M
CPUQuota=50%

# Filesystem
ReadWritePaths=/var/log/waterwall /run/waterwall
ReadOnlyPaths=/etc/waterwall /opt/waterwall
LogsDirectory=waterwall
RuntimeDirectory=waterwall
# Argus issue #15: default RuntimeDirectoryPreserve=no removes /run/waterwall
# on every restart — including the weekly timer — silently disarming a
# sentinel-armed kill switch. Preserve across restarts (still cleared on stop).
RuntimeDirectoryPreserve=restart

[Install]
WantedBy=multi-user.target
