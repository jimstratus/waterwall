# /etc/waterwall/client.env — single source of truth for the agent's egress config.
#
# The AI agent sources this (via shell profile) AND the canary reporter sources it,
# so the canary path == the agent path: if this file is wrong/missing, the canary
# fails too, surfacing a silent bypass. Edit here, not in individual shells.
export HTTPS_PROXY=http://127.0.0.1:8888
export NODE_EXTRA_CA_CERTS=/etc/waterwall/ca.pem
export NO_PROXY=127.0.0.1,localhost
